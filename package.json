{
  "name": "goldenwing-website",
  "version": "1.0.0",
  "private": true,
  "description": "GoldenWing Creative Studios - Agentur-Website",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "generate:types": "payload generate:types",
    "payload": "payload",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --no-warn-ignored"
    ],
    "src/**/*.{css,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.30.0",
    "@payloadcms/next": "^3.30.0",
    "@payloadcms/plugin-seo": "^3.30.0",
    "@payloadcms/richtext-lexical": "^3.30.0",
    "@payloadcms/storage-s3": "^3.30.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "framer-motion": "^12.34.5",
    "lucide-react": "^0.563.0",
    "next": "15.3.9",
    "nodemailer": "^8.0.1",
    "payload": "^3.30.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "15.3.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "postcss": "^8.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}
