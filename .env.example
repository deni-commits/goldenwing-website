# Payload CMS
PAYLOAD_SECRET=your-payload-secret-min-32-chars
DATABASE_URL=postgresql://user:pass@localhost:5432/goldenwing_dev

# Site
NEXT_PUBLIC_SITE_URL=https://dev.goldenwing.at

# ISR Revalidation
REVALIDATE_SECRET=your-revalidation-secret

# Media Storage (Cloudflare R2)
S3_BUCKET=goldenwing-media
S3_REGION=auto
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# SMTP (Contact Form)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@goldenwing.at
SMTP_PASS=your-app-password
TEAM_EMAIL=team@goldenwing.at

# Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Sentry (optional)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
