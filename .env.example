# Payload CMS
PAYLOAD_SECRET=your-payload-secret-min-32-chars
DATABASE_URL=postgresql://user:pass@host:5432/goldenwing

# Site
NEXT_PUBLIC_SITE_URL=https://goldenwing.at

# Media Storage (Cloudflare R2 or S3)
S3_BUCKET=goldenwing-media
S3_REGION=auto
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
